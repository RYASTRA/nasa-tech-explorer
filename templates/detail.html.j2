<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ record.title }} — nasa-tech-explorer</title>
  <meta name="description" content="{{ record.abstract[:150] }}">
  <link rel="stylesheet" href="../assets/style.css">
</head>
<body>
<header>
  <p><a href="../index.html">← All NASA tech</a></p>
  <p class="badge badge-{{ record.dataset }}">{{ dataset_label }}</p>
  <h1>{{ record.title }}</h1>
</header>
<main>
  <dl class="meta">
    {% if record.case_number %}<dt>Case number</dt><dd>{{ record.case_number }}</dd>{% endif %}
    {% if record.center %}<dt>NASA center</dt><dd>{{ record.center }}</dd>{% endif %}
    {% if record.category %}<dt>Category</dt><dd>{{ record.category }}</dd>{% endif %}
    <dt>First seen</dt><dd>{{ record.first_seen }}</dd>
  </dl>
  <p class="abstract">{{ record.abstract }}</p>
  <p><a class="cta" href="{{ link }}" rel="noopener">{{ link_label }} ↗</a></p>
</main>
<footer>
  <p>Not affiliated with or endorsed by NASA. Data from the public
     <a href="https://technology.nasa.gov/api/">NASA T2 API</a>.</p>
</footer>
</body>
</html>
